# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string (AWS RDS example)
DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/blacklist_db

# Static Bearer token clients must send in the Authorization header
# Example:  Authorization: Bearer my-secret-token-123
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Set to "production" on AWS
FLASK_ENV=development
